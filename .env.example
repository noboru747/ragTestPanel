# PostgreSQL
POSTGRES_DB=rga_km
POSTGRES_USER=rga_user
POSTGRES_PASSWORD=rga_pass

# Ollama models
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2:3b
VISION_MODEL=qwen2.5vl:7b

# Next.js (frontend → backend, docker internal network)
BACKEND_URL=http://backend:8000

# Feature flags
NEXT_PUBLIC_SHOW_OCR=false

# NODE_ENV is automatically set by Next.js (development/production)
# In development, API routes will fallback to mock data if backend is unreachable

# Cloudflare Tunnel（本機 credentials 目錄路徑，不含 credentials JSON 本身）
# Windows 範例：CLOUDFLARED_CREDS=C:\Users\your_username\.cloudflared
# Linux 範例：CLOUDFLARED_CREDS=/home/your_username/.cloudflared
CLOUDFLARED_CREDS=C:\Users\your_username\.cloudflared
